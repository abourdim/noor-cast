{
  "name": "noor-cast",
  "version": "0.9.31",
  "private": true,
  "type": "module",
  "description": "Kids-friendly multi-cam screen recorder",
  "scripts": {
    "start": "serve -p 8765 .",
    "lint": "eslint noorcast.js",
    "lint:fix": "eslint noorcast.js --fix",
    "test:syntax": "node --check noorcast.js && node --check sw.js",
    "test:cjs": "node tests/save-verification.cjs && node tests/silent-helpers.cjs && node tests/reels-mode.cjs && node tests/ux-arc.cjs && node tests/check-links.cjs",
    "check": "npm run test:syntax && npm run lint && npm run test:cjs",
    "test": "npx playwright test",
    "test:update": "npx playwright test --update-snapshots"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "eslint": "^9.0.0",
    "serve": "^14.2.6"
  }
}
